func plusOne(digits []int) []int {
    i := len(digits) - 1;

    for i >= 0 {
        digits[i]++;

        if digits[i] < 10 {
            return digits;
        }

        digits[i] = 0;
        i--
    }

    return append([]int{1}, digits...);
}