Language: Golang

Phương pháp giải: Runtime: 1ms, Memory: 8MB

func firstUniqChar(s string) int {
    count := [26]int{};

    for i := 0; i < len(s); i++ {
        count[s[i] - 'a']++;
    }

    for i := 0; i < len(s); i++ {
        if count[s[i] - 'a'] == 1 {
            return i;
        }
    }

    return -1;

}