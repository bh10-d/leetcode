Language: Golang

Phương pháp giải: Runtime: 1ms, Memory: 11.5MB

func findDisappearedNumbers(nums []int) []int {
    n := len(nums);
    seen := make([]bool, n);

    for _, v := range nums {
        seen[v - 1] = true;
    }

    var result []int;
    for i := 0; i < n; i++ {
        if !seen[i] {
            result = append(result, i+1);
        }
    }
    return result;
}