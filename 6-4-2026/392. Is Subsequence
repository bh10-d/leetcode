-- So sánh ký tự tại chuỗi s và tăng dần s khi so sánh trùng với ký tự trong chuỗi t

func isSubsequence(s string, t string) bool {
    i, j := 0, 0

    for i < len(s) && j < len(t) {
        if s[i] == t[j] {
            i++
        }
        j++
    }

    return i == len(s)
}