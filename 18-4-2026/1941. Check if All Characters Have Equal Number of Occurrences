func areOccurrencesEqual(s string) bool {
    m := make(map[byte]int);

    for i := 0; i < len(s); i++ {
        m[s[i]]++
    }

    var freq int

    for _, v := range m {
        if freq == 0 {
            freq = v
        } else if v != freq {
            return false
        }
    } 
    return true
}