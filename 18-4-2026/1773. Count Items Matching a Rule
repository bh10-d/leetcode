func countMatches(items [][]string, ruleKey string, ruleValue string) int {
    index := 0

    if ruleKey == "type" {
        index = 0
    } else if ruleKey == "color" {
        index = 1
    } else {
        index = 2
    }

    count :=0

    for i := 0; i < len(items); i++ {
        if items[i][index] == ruleValue {
            count++
        }
    }

    return count
}