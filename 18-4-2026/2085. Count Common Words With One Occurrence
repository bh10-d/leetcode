Language: Golang

Phương pháp giải: Runtime: 2ms, Memory: 8.6MB

func countWords(words1 []string, words2 []string) int {
    m1 := make(map[string]int)
    m2 := make(map[string]int)

    for _, w := range words1 {
        m1[w]++
    }

    for _, w := range words2 {
        m2[w]++
    }

    count := 0

    for w, c := range m1 {
        if c == 1 && m2[w] == 1 {
            count++
        }
    }

    return count
}