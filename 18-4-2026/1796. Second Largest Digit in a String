func secondHighest(s string) int {
    max1, max2 := -1, -1;

    for i := 0; i < len(s); i++ {
        if s[i] >= '0' && s[i] <= '9' {
            num := int(s[i] -  '0')

            if num > max1 {
                max2 = max1
                max1 = num
            } else if num > max2 && num < max1 {
                max2 = num
            }
        }
    }

    return max2
}