func sortArray(nums []int) []int {
    if len(nums) <= 1 {
        return nums
    }

    mid := len(nums)/2

    left := sortArray(nums[:mid])
    right := sortArray(nums[mid:])

    return merge(left, right);
}

func merge (a []int, b []int) []int {
    res := []int{}
    i,j := 0,0

    for i < len(a) && j < len(b) {
        if a[i] < b[j] {
            res = append(res, a[i])
            i++
        } else {
            res = append(res, b[j])
            j++
        }
    }

    for i< len(a) {
        res = append(res, a[i])
        i++
    }

    for j < len(b) {
        res = append(res, b[j])
        j++
    }

    return res
}