Language: Golang

Phương pháp giải: Runtime: 0ms, Memory: 4MB

func distributeCandies(candies int, num_people int) []int {
    res := make([]int, num_people)

    give := 1
    i := 0

    for candies > 0 {
        idx := i % num_people

        if candies < give {
            res[idx] += candies
            break
        }

        res[idx] += give
        candies -= give

        give++
        i++
    }
    return res
}