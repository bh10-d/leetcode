Language: Golang

Phương pháp giải: Runtime: 0ms, Memory: 4.1MB

func numJewelsInStones(jewels string, stones string) int {
    m := make(map[byte]int);

    total := 0;

    for i := 0; i < len(jewels); i++ {
        m[jewels[i]] = 0;
    }



    for i := 0; i < len(stones); i++ {
        if _, ok := m[stones[i]]; ok {
            m[stones[i]]++
        }
    }

    for _, v := range m {
        total += v;
    }

    return total;
}