func findPoisonedDuration(timeSeries []int, duration int) int {
    if len(timeSeries) == 0 {
        return 0;
    }

    total := 0;

    for i := 1; i < len(timeSeries); i++ {
        gap := timeSeries[i] - timeSeries[i-1];

        if gap >= duration {
            total += duration;
        } else {
            total += gap;
        }
    }
    total += duration;
    return total;
}