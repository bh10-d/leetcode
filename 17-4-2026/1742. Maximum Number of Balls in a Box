Language: Golang

Phương pháp giải: Runtime: 13ms, Memory: 4.1MB

func sumDigits(n int) int {
    sum := 0
    for n > 0 {
        sum += n%10;
        n /=10;
    }
    return sum;
}

func countBalls(lowLimit int, highLimit int) int {
    m := make(map[int]int);
    maxVal := 0;

    for i := lowLimit; i <= highLimit; i++ {
        box := sumDigits(i);

        m[box]++;

        if m[box] > maxVal {
            maxVal = m[box];
        }
    }

    return maxVal;
}