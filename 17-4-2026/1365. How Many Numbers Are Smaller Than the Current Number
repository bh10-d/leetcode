Language: Golang

Phương pháp giải: Runtime: 2ms, Memory: 4.8MB

func smallerNumbersThanCurrent(nums []int) []int {
    var m []int;

    count := 0;

    for i := 0; i < len(nums); i++ {
        for j := 0; j < len(nums); j++ {
            if nums[i] > nums[j] {
                count++;
            }
        }
        m = append(m, count);
        count = 0;
    }

    return m;
}